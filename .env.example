# Microworkers credentials (username = account email on login.php)
MICROWORKERS_USERNAME=
MICROWORKERS_PASSWORD=

# Where the account lives
MICROWORKERS_BASE_URL=https://www.microworkers.com

# Optional OpenAI for task classification (phone/SMS/OTP detection)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CLASSIFY_TASKS=true
OPENAI_SKIP_CONFIDENCE_THRESHOLD=0.7
# Task finished? Uses OpenAI on page text when true + OPENAI_API_KEY (no regex). Set false for keyword-only fallback.
OPENAI_CLASSIFY_COMPLETION=true
OPENAI_COMPLETION_CONFIDENCE_THRESHOLD=0.72
# 1 = check every automation step (more accurate); 2+ = fewer API calls
OPENAI_COMPLETION_EVERY_N_STEPS=1
OPENAI_NAVIGATOR=true
# Optional; if unset, uses min(2000000, MAX_TASKS_PER_RUN * 40)
# OPENAI_NAVIGATOR_MAX_STEPS=

# Max tasks / job pages to attempt per automation run (default 45000 in config if unset)
MAX_TASKS_PER_RUN=45000

# CapSolver (https://www.capsolver.com) — Turnstile, reCAPTCHA v2, hCaptcha; optional Cloudflare interstitial
CAPSOLVER_API_KEY=
CAPSOLVER_ENABLED=true
# Static/sticky proxy (format ip:port:user:pass) — required only for AntiCloudflareTask interstitial
CAPSOLVER_CLOUDFLARE_PROXY=

# Playwright browser mode (set false to see a visible browser window locally)
BROWSER_HEADLESS=false

# Local session persistence (cookies)
STORAGE_STATE_PATH=data/microworkers-storage-state.json

# Pause when the automation cannot safely continue (autonomous best-effort -> false)
SAFE_MANUAL_PAUSE=false

# Server port for dashboard
STREAM_PORT=3000

# Railway uses PORT; optional locally
PORT=3000

# Optional: expose a realtime headful browser via noVNC.
# Set ENABLE_VNC=true on Railway, then open the Railway service URL for port 6080.
ENABLE_VNC=false
VNC_WEB_PORT=6080

